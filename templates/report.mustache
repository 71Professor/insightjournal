{{!
    @template mod_insightjournal/report

    Activity report listing every participant's response with a search filter.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * backurl - URL back to the activity view.
    * downloadurl - URL to download the report as CSV.
    * actionurl - Form action URL for the search filter.
    * cmid - Course module id.
    * search - Current search term.
    * hasrows - Whether there are any rows to display.
    * rows - List of response rows.
        * summaryurl - URL to the participant's personal summary.
        * fullname - Participant full name.
        * email - Participant email.
        * response - Response text.
        * timemodified - Localised last modified date.

    Example context (json):
    {
        "backurl": "https://example.com/mod/insightjournal/view.php?id=5",
        "downloadurl": "https://example.com/mod/insightjournal/report.php?id=5&download=csv",
        "actionurl": "https://example.com/mod/insightjournal/report.php",
        "cmid": 5,
        "search": "",
        "hasrows": true,
        "rows": [
            {
                "summaryurl": "https://example.com/mod/insightjournal/summary.php?courseid=2&userid=3",
                "fullname": "Jane Doe",
                "email": "jane@example.com",
                "response": "Today I learned about Mustache templates.",
                "timemodified": "1 January 2026, 10:00 AM"
            }
        ]
    }
}}
<div class="insightjournal-report">
    <div class="mb-3">
        <a href="{{backurl}}" class="btn btn-secondary">{{#str}}backtoactivity, mod_insightjournal{{/str}}</a>
        <a href="{{downloadurl}}" class="btn btn-primary">{{#str}}downloadcsv, mod_insightjournal{{/str}}</a>
    </div>

    <form method="get" action="{{actionurl}}" class="mb-3">
        <input type="hidden" name="id" value="{{cmid}}">
        <label for="insightjournal-search" class="sr-only">{{#str}}searchparticipants, mod_insightjournal{{/str}}</label>
        <div class="input-group">
            <input id="insightjournal-search" type="text" name="search" value="{{search}}" class="form-control" placeholder="{{#str}}searchparticipants, mod_insightjournal{{/str}}">
            <div class="input-group-append">
                <button type="submit" class="btn btn-outline-secondary">{{#str}}search{{/str}}</button>
            </div>
        </div>
    </form>

    {{#hasrows}}
        <table class="generaltable">
            <thead>
                <tr>
                    <th scope="col">{{#str}}participant, mod_insightjournal{{/str}}</th>
                    <th scope="col">{{#str}}response, mod_insightjournal{{/str}}</th>
                    <th scope="col">{{#str}}timemodified, mod_insightjournal{{/str}}</th>
                </tr>
            </thead>
            <tbody>
                {{#rows}}
                    <tr>
                        <td>
                            <a href="{{summaryurl}}">{{fullname}}</a>
                            <div class="small text-muted">{{email}}</div>
                        </td>
                        <td><div class="insightjournal-response-text">{{response}}</div></td>
                        <td>{{timemodified}}</td>
                    </tr>
                {{/rows}}
            </tbody>
        </table>
    {{/hasrows}}
    {{^hasrows}}
        <div class="alert alert-info">{{#str}}noentries, mod_insightjournal{{/str}}</div>
    {{/hasrows}}
</div>
