{{!
    @template mod_insightjournal/coursereport

    Course-wide report showing every participant's completion across all insight journal activities.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * backurl - URL back to the course.
    * downloadurl - URL to download the report as CSV.
    * hasactivities - Whether there are any activities to display.
    * activities - Column headers, one per activity.
        * name - Activity name.
    * rows - One row per participant.
        * summaryurl - URL to the participant's personal summary.
        * fullname - Participant full name.
        * cells - One cell per activity.
            * completed - Whether the entry is complete.
            * status - Localised status text.
            * timemodified - Localised last modified date, or empty.
        * progress - Localised overall progress text.

    Example context (json):
    {
        "backurl": "https://example.com/course/view.php?id=2",
        "downloadurl": "https://example.com/mod/insightjournal/coursereport.php?courseid=2&download=csv",
        "hasactivities": true,
        "activities": [
            {"name": "Week 1 reflection"}
        ],
        "rows": [
            {
                "summaryurl": "https://example.com/mod/insightjournal/summary.php?courseid=2&userid=3",
                "fullname": "Jane Doe",
                "cells": [
                    {"completed": true, "status": "Done", "timemodified": "1 January 2026, 10:00 AM"}
                ],
                "progress": "1 / 1"
            }
        ]
    }
}}
<div class="insightjournal-course-report">
    <div class="mb-3">
        <a href="{{backurl}}" class="btn btn-secondary">{{#str}}backtocourse, mod_insightjournal{{/str}}</a>
        <a href="{{downloadurl}}" class="btn btn-primary">{{#str}}downloadcsv, mod_insightjournal{{/str}}</a>
    </div>

    {{#hasactivities}}
        <table class="generaltable">
            <thead>
                <tr>
                    <th scope="col">{{#str}}participant, mod_insightjournal{{/str}}</th>
                    {{#activities}}<th scope="col">{{name}}</th>{{/activities}}
                    <th scope="col">{{#str}}progress, mod_insightjournal{{/str}}</th>
                </tr>
            </thead>
            <tbody>
                {{#rows}}
                    <tr>
                        <td><a href="{{summaryurl}}">{{fullname}}</a></td>
                        {{#cells}}
                            <td>
                                <span class="{{#completed}}text-success{{/completed}}{{^completed}}text-muted{{/completed}}">{{status}}</span>
                                {{#timemodified}}<div class="small text-muted">{{timemodified}}</div>{{/timemodified}}
                            </td>
                        {{/cells}}
                        <td>{{progress}}</td>
                    </tr>
                {{/rows}}
            </tbody>
        </table>
    {{/hasactivities}}
    {{^hasactivities}}
        <div class="alert alert-info">{{#str}}noreflectionsincourse, mod_insightjournal{{/str}}</div>
    {{/hasactivities}}
</div>
